{
  "scenarios": {
    "phase1_low_load": {
      "executor": "constant-arrival-rate",
      "rate": 2,
      "timeUnit": "1s",
      "duration": "3m",
      "preAllocatedVUs": 2,
      "maxVUs": 5
    },
    "phase2_medium_load": {
      "executor": "ramping-arrival-rate",
      "startRate": 1,
      "timeUnit": "1s",
      "stages": [
        { "target": 9, "duration": "2m" },
        { "target": 9, "duration": "5m" },
        { "target": 0, "duration": "1m" }
      ],
      "preAllocatedVUs": 15,
      "maxVUs": 50
    },
    "phase3_high_load": {
      "executor": "ramping-arrival-rate",
      "startRate": 10,
      "timeUnit": "1s",
      "stages": [
        { "target": 50, "duration": "3m" },
        { "target": 170, "duration": "5m" },
        { "target": 200, "duration": "10m" },
        { "target": 0, "duration": "2m" }
      ],
      "preAllocatedVUs": 100,
      "maxVUs": 500
    }
  },
  "thresholds": {
    "http_req_failed": [
      {
        "threshold": "rate<0.01",
        "abortOnFail": true,
        "delayAbortEval": "10s"
      }
    ],
    "http_req_duration{scenario:phase1_low_load}": [
      "p(95)<500",
      "p(99)<1000"
    ],
    "http_req_duration{scenario:phase2_medium_load}": [
      "p(95)<1000",
      "p(99)<2000"
    ],
    "http_req_duration{scenario:phase3_high_load}": [
      "p(95)<1500",
      "p(99)<3000"
    ]
  }
}