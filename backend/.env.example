# 給 MySQL Docker 啟動時看的 (建立初始環境)
MYSQL_ROOT_PASSWORD=PASSWORD_group11_ROOT
MYSQL_DATABASE=job_scheduler
MYSQL_USER=api_worker
MYSQL_PASSWORD=PASSWORD_group11

# ==========================================
# 資料庫連線設定 (Database Connection)
# ==========================================

# ⚠️ 注意：請根據你的執行環境選擇取消註解 (Uncomment) 哪一行

# 情境 A：如果你是在本機直接執行 Python (例如 python database.py)
# 請將檔案命名為 .env.local，並使用 localhost
# DATABASE_URL=mysql+pymysql://api_worker:PASSWORD_group11@localhost:3306/job_scheduler

# 情境 B：如果你是要使用 Docker Compose 啟動
# 請將檔案命名為 .env，並使用 db
# DATABASE_URL=mysql+pymysql://api_worker:PASSWORD_group11@db:3306/job_scheduler

# ==========================================
# Password reset email / SMTP settings
# ==========================================
# The reset link will be generated as:
#   RESET_PASSWORD_BASE_URL?reset_token=...
RESET_PASSWORD_BASE_URL=http://localhost:3000

# Gmail example:
# 1. Enable 2-step verification on the sender Gmail account.
# 2. Create an App Password.
# 3. Uncomment these lines and replace them with real values.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_FROM=noreplyjobschedulersystem@gmail.com
# SMTP_FROM_NAME=no-reply
# SMTP_USERNAME=noreplyjobschedulersystem@gmail.com
# SMTP_PASSWORD=vrzkfuxzlowqlfmm
